server:
  port: 9000

spring:
  application:
    name: api-gateway
  cloud:
    gateway:
      routes:
        # Route for Authentication Service
        - id: auth-service
          uri: lb://AUTH-SERVICE
          predicates:
            - Path=/auth/**

        # Route for Book/Catalog Service
        - id: book-service
          uri: lb://BOOK-SERVICE
          predicates:
            - Path=/books/**, /categories/**

eureka:
  client:
    service-url:
      defaultZone: http://localhost:8761/eureka/

# Enable Gateway to find services via Eureka name (lb://)
spring.cloud.gateway.discovery.locator.enabled: true