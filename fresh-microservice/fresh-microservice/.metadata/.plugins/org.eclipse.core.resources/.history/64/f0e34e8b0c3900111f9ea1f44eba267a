server:
  port: 9000

spring:
  application:
    name: api-gateway
  cloud:
    gateway:
      # This allows the Gateway to automatically create routes based on Eureka service names
      discovery:
        locator:
          enabled: true
          lower-case-service-id: true
      routes:
        - id: auth-route
          uri: lb://AUTH-SERVICE
          predicates:
            - Path=/auth/**

        - id: book-route
          uri: lb://BOOK-SERVICE
          predicates:
            - Path=/books/**, /categories/**

eureka:
  client:
    service-url:
      defaultZone: http://localhost:8761/eureka/